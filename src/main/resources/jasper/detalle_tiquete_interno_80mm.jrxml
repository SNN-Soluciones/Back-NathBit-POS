<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
	name="detalle_tiquete_interno_80mm"
	pageWidth="216" pageHeight="792" columnWidth="196"
	leftMargin="10" rightMargin="10" topMargin="0" bottomMargin="0"
	uuid="7a8b9c0d-e1f2-3456-7890-abcdef123456">

	<field name="cantidad"      class="java.math.BigDecimal"/>
	<field name="descripcion"   class="java.lang.String"/>
	<field name="precioUnitario" class="java.math.BigDecimal"/>
	<field name="subtotal"      class="java.math.BigDecimal"/>
	<field name="descuento"     class="java.math.BigDecimal"/>

	<background><band/></background>

	<detail>
		<band height="40" splitType="Stretch">

			<!-- Cantidad -->
			<textField>
				<reportElement x="0" y="2" width="20" height="10"
					uuid="8b9c0d1e-f234-5678-901a-bcdef2345678"/>
				<textElement textAlignment="Right">
					<font fontName="DejaVu Sans" size="8" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>

			<!-- Nombre del producto -->
			<textField textAdjust="StretchHeight">
				<reportElement x="25" y="2" width="171" height="18"
					uuid="9c0d1e2f-3456-789a-bc01-def345678901"/>
				<textElement textAlignment="Left">
					<font fontName="DejaVu Sans" size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>

			<!-- Línea: precioUnitario × cantidad = subtotal -->
			<frame>
				<reportElement positionType="Float" x="25" y="20" width="171" height="10"
					uuid="9c0d1e2f-3456-789a-bc01-def345678907"/>
				<textField pattern="#,##0.00">
					<reportElement x="0" y="1" width="50" height="9"
						uuid="9c0d1e2f-3456-789a-bc01-def345678987"/>
					<textElement textAlignment="Right">
						<font fontName="DejaVu Sans" size="7"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{precioUnitario}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="50" y="1" width="15" height="9"
						uuid="9c0d1e2f-3456-789a-bc01-def345678902"/>
					<textElement textAlignment="Center">
						<font fontName="DejaVu Sans" size="7"/>
					</textElement>
					<text><![CDATA[x]]></text>
				</staticText>
				<textField>
					<reportElement x="65" y="1" width="20" height="9"
						uuid="9c0d1e2f-3456-789a-bc01-def345678903"/>
					<textElement textAlignment="Center">
						<font fontName="DejaVu Sans" size="7"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
				</textField>
				<staticText>
					<reportElement x="85" y="1" width="15" height="9"
						uuid="9c0d1e2f-3456-789a-bc01-def345678904"/>
					<textElement textAlignment="Center">
						<font fontName="DejaVu Sans" size="7"/>
					</textElement>
					<text><![CDATA[=]]></text>
				</staticText>
				<textField pattern="#,##0.00">
					<reportElement x="100" y="1" width="71" height="9"
						uuid="9c0d1e2f-3456-789a-bc01-def345678905"/>
					<textElement textAlignment="Right">
						<font fontName="DejaVu Sans" size="7" isBold="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{subtotal}]]></textFieldExpression>
				</textField>
			</frame>

			<!-- Línea de descuento (solo si descuento > 0) -->
			<frame>
				<reportElement positionType="Float" x="25" y="31" width="171" height="9"
					uuid="aa000001-1111-2222-3333-444444444401">
					<printWhenExpression><![CDATA[$F{descuento} != null && $F{descuento}.compareTo(java.math.BigDecimal.ZERO) > 0]]></printWhenExpression>
				</reportElement>
				<staticText>
					<reportElement x="0" y="0" width="100" height="9"
						uuid="aa000001-1111-2222-3333-444444444402"/>
					<textElement textAlignment="Left">
						<font fontName="DejaVu Sans" size="7" isItalic="true"/>
					</textElement>
					<text><![CDATA[  Descuento promo:]]></text>
				</staticText>
				<textField pattern="#,##0.00">
					<reportElement x="100" y="0" width="71" height="9"
						uuid="aa000001-1111-2222-3333-444444444403"/>
					<textElement textAlignment="Right">
						<font fontName="DejaVu Sans" size="7" isItalic="true"/>
					</textElement>
					<textFieldExpression><![CDATA[$F{descuento}.negate()]]></textFieldExpression>
				</textField>
			</frame>

		</band>
	</detail>
</jasperReport>