<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
	name="factura_electronica_cr" pageWidth="612" pageHeight="792"
	columnWidth="555" leftMargin="20" rightMargin="20"
	topMargin="20" bottomMargin="20">

	<!-- Parámetros principales -->
	<parameter name="clave" class="java.lang.String"/>
	<parameter name="consecutivo" class="java.lang.String"/>
	<parameter name="tipo_documento" class="java.lang.String"/>
	<parameter name="fecha_emision" class="java.lang.String"/>

	<!-- Datos del emisor -->
	<parameter name="emisor_nombre" class="java.lang.String"/>
	<parameter name="emisor_identificacion" class="java.lang.String"/>
	<parameter name="emisor_telefono" class="java.lang.String"/>
	<parameter name="emisor_correo" class="java.lang.String"/>
	<parameter name="emisor_direccion" class="java.lang.String"/>
	<parameter name="logo_empresa" class="java.lang.Object"/>
	<parameter name="tiene_logo" class="java.lang.Boolean"/>

	<!-- Datos del receptor -->
	<parameter name="receptor_nombre" class="java.lang.String"/>
	<parameter name="receptor_identificacion" class="java.lang.String"/>
	<parameter name="receptor_telefono" class="java.lang.String"/>
	<parameter name="receptor_correo" class="java.lang.String"/>
	<parameter name="receptor_direccion" class="java.lang.String"/>

	<!-- Condiciones comerciales -->
	<parameter name="condicion_venta" class="java.lang.String"/>
	<parameter name="medio_pago" class="java.lang.String"/>
	<parameter name="tipo_cambio" class="java.lang.String"/>
	<parameter name="moneda" class="java.lang.String"/>
	<parameter name="simbolo_moneda" class="java.lang.String"/>

	<!-- Totales -->
	<parameter name="total_venta" class="java.lang.String"/>
	<parameter name="total_descuentos" class="java.lang.String"/>
	<parameter name="total_venta_neta" class="java.lang.String"/>
	<parameter name="total_impuesto" class="java.lang.String"/>
	<parameter name="total_otros_cargos" class="java.lang.String"/>
	<parameter name="total_comprobante" class="java.lang.String"/>
	<parameter name="total_exonerado" class="java.lang.String"/>
	<parameter name="qr_image" class="java.lang.Object"/>

	<!-- Otros -->
	<parameter name="observaciones" class="java.lang.String"/>
	<parameter name="qr_data" class="java.lang.String"/>
	<parameter name="mensaje_hacienda" class="java.lang.String"/>
	<parameter name="atendido_por" class="java.lang.String"/>

	<!-- DataSources -->
	<parameter name="detalles" class="java.util.List"/>
	<parameter name="exoneraciones" class="java.util.List"/>
	<parameter name="tiene_exoneraciones" class="java.lang.Boolean"/>
	<parameter name="otros_cargos" class="java.util.List"/>
	<parameter name="tiene_otros_cargos" class="java.lang.Boolean"/>

	<!-- Fields para el detalle -->
	<field name="codigo" class="java.lang.String"/>
	<field name="descripcion" class="java.lang.String"/>
	<field name="cantidad" class="java.lang.String"/>
	<field name="unidad" class="java.lang.String"/>
	<field name="precio_unitario" class="java.lang.String"/>
	<field name="descuento" class="java.lang.String"/>
	<field name="subtotal" class="java.lang.String"/>
	<field name="impuesto" class="java.lang.String"/>
	<field name="monto_total" class="java.lang.String"/>

	<background>
		<band splitType="Stretch"/>
	</background>

	<title>
		<band height="180" splitType="Stretch">
			<!-- Encabezado con logo y datos empresa -->
			<rectangle>
				<reportElement x="0" y="0" width="572" height="100" forecolor="#1E3A8A" backcolor="#EFF6FF"/>
				<graphicElement>
					<pen lineWidth="0.0"/>
				</graphicElement>
			</rectangle>

			<!-- Logo empresa -->
			<image scaleImage="RetainShape" hAlign="Center" vAlign="Middle" isUsingCache="true">
				<reportElement x="10" y="10" width="80" height="80">
					<printWhenExpression><![CDATA[$P{tiene_logo}]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA[$P{logo_empresa} instanceof java.io.InputStream ?
                    $P{logo_empresa} :
                    new java.io.ByteArrayInputStream((byte[])$P{logo_empresa})]]></imageExpression>
			</image>

			<!-- Datos de la empresa -->
			<textField>
				<reportElement x="100" y="10" width="300" height="25" forecolor="#1E3A8A"/>
				<textElement>
					<font size="16" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{emisor_nombre}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="100" y="35" width="300" height="15" forecolor="#374151"/>
				<textElement>
					<font size="10"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{emisor_identificacion}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="100" y="50" width="300" height="15" forecolor="#374151"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA["Tel: " + $P{emisor_telefono} + " | " + $P{emisor_correo}]]></textFieldExpression>
			</textField>

			<textField textAdjust="StretchHeight">
				<reportElement x="100" y="65" width="300" height="25" forecolor="#374151"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{emisor_direccion}]]></textFieldExpression>
			</textField>

			<!-- Tipo de documento -->
			<rectangle>
				<reportElement x="410" y="10" width="155" height="80" forecolor="#1E3A8A" backcolor="#1E3A8A"/>
				<graphicElement>
					<pen lineWidth="0.0"/>
				</graphicElement>
			</rectangle>

			<textField>
				<reportElement x="410" y="15" width="155" height="25" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="14" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{tipo_documento}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="410" y="45" width="60" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<text><![CDATA[Nº Factura:]]></text>
			</staticText>

			<textField>
				<reportElement x="410" y="60" width="155" height="20" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center">
					<font size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{consecutivo}]]></textFieldExpression>
			</textField>

			<!-- Información del documento -->
			<rectangle>
				<reportElement x="0" y="110" width="572" height="60" forecolor="#E5E7EB"/>
				<graphicElement>
					<pen lineWidth="1.0"/>
				</graphicElement>
			</rectangle>

			<!-- Clave -->
			<staticText>
				<reportElement x="10" y="115" width="40" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Clave:]]></text>
			</staticText>

			<textField>
				<reportElement x="50" y="115" width="512" height="15" forecolor="#374151"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{clave}]]></textFieldExpression>
			</textField>

			<!-- Fecha, condición y medio de pago -->
			<staticText>
				<reportElement x="10" y="135" width="90" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Fecha Emisión:]]></text>
			</staticText>

			<textField>
				<reportElement x="100" y="135" width="150" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{fecha_emision}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="260" y="135" width="90" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Condición Venta:]]></text>
			</staticText>

			<textField>
				<reportElement x="350" y="135" width="100" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{condicion_venta}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="10" y="150" width="70" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Medio Pago:]]></text>
			</staticText>

			<textField>
				<reportElement x="80" y="150" width="100" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{medio_pago}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="200" y="150" width="80" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Tipo Cambio:]]></text>
			</staticText>

			<textField>
				<reportElement x="280" y="150" width="60" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{tipo_cambio}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="350" y="150" width="50" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Moneda:]]></text>
			</staticText>

			<textField>
				<reportElement x="400" y="150" width="40" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{moneda}]]></textFieldExpression>
			</textField>
		</band>
	</title>

	<pageHeader>
		<band height="90" splitType="Stretch">
			<!-- Datos del cliente -->
			<rectangle>
				<reportElement x="0" y="5" width="572" height="80" forecolor="#E5E7EB" backcolor="#F9FAFB"/>
				<graphicElement>
					<pen lineWidth="1.0"/>
				</graphicElement>
			</rectangle>

			<staticText>
				<reportElement x="10" y="10" width="100" height="20" forecolor="#1E3A8A"/>
				<textElement>
					<font size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[RECEPTOR:]]></text>
			</staticText>

			<staticText>
				<reportElement x="10" y="30" width="50" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Nombre:]]></text>
			</staticText>

			<textField>
				<reportElement x="60" y="30" width="250" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{receptor_nombre}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="320" y="30" width="80" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Identificación:]]></text>
			</staticText>

			<textField>
				<reportElement x="400" y="30" width="160" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{receptor_identificacion}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="10" y="50" width="50" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Correo:]]></text>
			</staticText>

			<textField>
				<reportElement x="60" y="50" width="250" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{receptor_correo}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="320" y="50" width="50" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Teléfono:]]></text>
			</staticText>

			<textField>
				<reportElement x="370" y="50" width="190" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{receptor_telefono}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="10" y="65" width="60" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Dirección:]]></text>
			</staticText>

			<textField textAdjust="StretchHeight">
				<reportElement x="70" y="65" width="490" height="15"/>
				<textElement>
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{receptor_direccion}]]></textFieldExpression>
			</textField>
		</band>
	</pageHeader>

	<columnHeader>
		<band height="30" splitType="Stretch">
			<!-- Encabezado de la tabla de detalles -->
			<rectangle>
				<reportElement x="0" y="5" width="572" height="25" forecolor="#1E3A8A" backcolor="#1E3A8A"/>
				<graphicElement>
					<pen lineWidth="0.0"/>
				</graphicElement>
			</rectangle>

			<staticText>
				<reportElement x="5" y="10" width="45" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Código]]></text>
			</staticText>

			<staticText>
				<reportElement x="55" y="10" width="200" height="15" forecolor="#FFFFFF"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Descripción]]></text>
			</staticText>

			<staticText>
				<reportElement x="260" y="10" width="40" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Center">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Cant.]]></text>
			</staticText>

			<staticText>
				<reportElement x="305" y="10" width="60" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[P. Unit]]></text>
			</staticText>

			<staticText>
				<reportElement x="370" y="10" width="50" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Desc.]]></text>
			</staticText>

			<staticText>
				<reportElement x="425" y="10" width="60" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Subtotal]]></text>
			</staticText>

			<staticText>
				<reportElement x="490" y="10" width="75" height="15" forecolor="#FFFFFF"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Total]]></text>
			</staticText>
		</band>
	</columnHeader>

	<detail>
		<band height="20" splitType="Stretch">
			<!-- Línea de detalle -->
			<rectangle>
				<reportElement x="0" y="0" width="572" height="20" forecolor="#E5E7EB">
					<printWhenExpression><![CDATA[new Boolean($V{REPORT_COUNT}.intValue() % 2 == 0)]]></printWhenExpression>
				</reportElement>
				<graphicElement>
					<pen lineWidth="0.0"/>
				</graphicElement>
			</rectangle>

			<textField>
				<reportElement x="5" y="2" width="45" height="16"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{codigo}]]></textFieldExpression>
			</textField>

			<textField textAdjust="StretchHeight">
				<reportElement x="55" y="2" width="200" height="16"/>
				<textElement verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="260" y="2" width="40" height="16"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{cantidad}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="305" y="2" width="60" height="16"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + $F{precio_unitario}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="370" y="2" width="50" height="16"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + $F{descuento}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="425" y="2" width="60" height="16"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + $F{subtotal}]]></textFieldExpression>
			</textField>

			<textField>
				<reportElement x="490" y="2" width="75" height="16"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="8" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + $F{monto_total}]]></textFieldExpression>
			</textField>

			<line>
				<reportElement x="0" y="19" width="572" height="1" forecolor="#E5E7EB"/>
			</line>
		</band>
	</detail>

	<columnFooter>
		<band splitType="Stretch"/>
	</columnFooter>

	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>

	<lastPageFooter>
		<band height="350" splitType="Stretch">
			<!-- Sección de totales -->
			<rectangle>
				<reportElement x="350" y="10" width="222" height="180" forecolor="#E5E7EB" backcolor="#F9FAFB"/>
				<graphicElement>
					<pen lineWidth="1.0"/>
				</graphicElement>
			</rectangle>

			<staticText>
				<reportElement x="360" y="15" width="100" height="15"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Total Ventas:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="15" width="95" height="15"/>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_venta}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="360" y="35" width="100" height="15"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Total Descuentos:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="35" width="95" height="15"/>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_descuentos}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="360" y="55" width="100" height="15"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Total Venta Neta:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="55" width="95" height="15"/>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_venta_neta}]]></textFieldExpression>
			</textField>

			<staticText>
				<reportElement x="360" y="75" width="100" height="15"/>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Total Impuestos:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="75" width="95" height="15"/>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_impuesto}]]></textFieldExpression>
			</textField>

			<!-- Total exonerado si aplica -->
			<staticText>
				<reportElement x="360" y="95" width="100" height="15">
					<printWhenExpression><![CDATA[$P{tiene_exoneraciones}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Total Exonerado:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="95" width="95" height="15">
					<printWhenExpression><![CDATA[$P{tiene_exoneraciones}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_exonerado}]]></textFieldExpression>
			</textField>

			<!-- Otros cargos si aplica -->
			<staticText>
				<reportElement x="360" y="115" width="100" height="15">
					<printWhenExpression><![CDATA[$P{tiene_otros_cargos}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right">
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[Otros Cargos:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="115" width="95" height="15">
					<printWhenExpression><![CDATA[$P{tiene_otros_cargos}]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Right">
					<font size="9"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_otros_cargos}]]></textFieldExpression>
			</textField>

			<line>
				<reportElement x="360" y="140" width="200" height="1" forecolor="#1E3A8A"/>
				<graphicElement>
					<pen lineWidth="2.0"/>
				</graphicElement>
			</line>

			<staticText>
				<reportElement x="360" y="150" width="100" height="20" forecolor="#1E3A8A"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="11" isBold="true"/>
				</textElement>
				<text><![CDATA[TOTAL:]]></text>
			</staticText>

			<textField>
				<reportElement x="465" y="150" width="95" height="20" forecolor="#1E3A8A"/>
				<textElement textAlignment="Right" verticalAlignment="Middle">
					<font size="11" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{simbolo_moneda} + " " + $P{total_comprobante}]]></textFieldExpression>
			</textField>

			<!-- Código QR -->
			<!-- QR como imagen desde parámetro -->
			<image>
				<reportElement x="10" y="10" width="120" height="120">
					<printWhenExpression><![CDATA[$P{qr_image} != null]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA[$P{qr_image}]]></imageExpression>
			</image>

			<!-- Observaciones -->
			<rectangle>
				<reportElement x="140" y="10" width="200" height="120" forecolor="#E5E7EB"/>
				<graphicElement>
					<pen lineWidth="1.0"/>
				</graphicElement>
			</rectangle>

			<staticText>
				<reportElement x="145" y="15" width="90" height="15"/>
				<textElement>
					<font size="9" isBold="true"/>
				</textElement>
				<text><![CDATA[OBSERVACIONES:]]></text>
			</staticText>

			<textField textAdjust="StretchHeight">
				<reportElement x="145" y="35" width="190" height="85"/>
				<textElement>
					<font size="8"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{observaciones}]]></textFieldExpression>
			</textField>

			<!-- Información de exoneración -->
			<subreport>
				<reportElement x="0" y="200" width="572" height="60" positionType="Float">
					<printWhenExpression><![CDATA[$P{tiene_exoneraciones}]]></printWhenExpression>
				</reportElement>
				<subreportParameter name="REPORT_DATA_SOURCE">
					<subreportParameterExpression>
						<![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($P{exoneraciones})]]>
					</subreportParameterExpression>
				</subreportParameter>
				<subreportExpression><![CDATA["jasper/subreport_exoneraciones.jasper"]]></subreportExpression>
			</subreport>

			<!-- Mensaje de Hacienda -->
			<textField>
				<reportElement x="0" y="270" width="572" height="20" forecolor="#374151" positionType="Float"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font size="8" isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$P{mensaje_hacienda}]]></textFieldExpression>
			</textField>

			<!-- Línea de firma -->
			<line>
				<reportElement x="10" y="320" width="200" height="1" positionType="Float"/>
			</line>

			<staticText>
				<reportElement x="10" y="325" width="200" height="15" positionType="Float"/>
				<textElement textAlignment="Center">
					<font size="9"/>
				</textElement>
				<text><![CDATA[Firma del Cliente]]></text>
			</staticText>

			<!-- Atendido por -->
			<textField>
				<reportElement x="350" y="325" width="222" height="15" positionType="Float"/>
				<textElement textAlignment="Right">
					<font size="8" isItalic="true"/>
				</textElement>
				<textFieldExpression><![CDATA["Lo atendió: " + ($P{atendido_por} != null ? $P{atendido_por} : "")]]></textFieldExpression>
			</textField>
		</band>
	</lastPageFooter>

	<summary>
		<band splitType="Stretch"/>
	</summary>
</jasperReport>