      <!-- Referencia (condicional) -->
      <textField textAdjust="StretchHeight">
        <reportElement x="0" y="73" width="206" height="9" uuid="aa000029-0000-0000-0000-000000000029">
          <printWhenExpression><![CDATA[$P{referencia} != null && !$P{referencia}.trim().isEmpty()]]></printWhenExpression>
