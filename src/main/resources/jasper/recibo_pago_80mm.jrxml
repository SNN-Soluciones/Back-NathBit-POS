        <textElement textAlignment="Left">
          <font fontName="DejaVu Sans" size="6"/>
        </textElement>
        <textFieldExpression><![CDATA["Factura origen: " + $P{numero_documento_origen}]]></textFieldExpression>
      </textField>

      <line>
        <reportElement x="0" y="42" width="206" height="1" uuid="aa000016-0000-0000-0000-000000000016"/>
        <graphicElement><pen lineStyle="Dotted"/></graphicElement>
      </line>
    </band>
  </pageHeader>

  <!-- ===== CUERPO: MONTOS ===== -->
