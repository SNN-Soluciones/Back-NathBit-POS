      <!-- Medio de pago -->
      <staticText>
        <reportElement x="0" y="62" width="110" height="9" uuid="aa000027-0000-0000-0000-000000000027"/>
        <textElement textAlignment="Left">
          <font fontName="DejaVu Sans" size="6"/>
