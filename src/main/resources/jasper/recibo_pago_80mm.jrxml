  <background><band/></background>

  <!-- ===== TÍTULO: LOGO + DATOS EMPRESA ===== -->
  <title>
    <band height="130" splitType="Stretch">

      <!-- Logo -->
      <image scaleImage="RetainShape" hAlign="Center">
        <reportElement x="63" y="0" width="80" height="40"
          uuid="aa000001-0000-0000-0000-000000000001">
          <printWhenExpression><![CDATA[$P{tiene_logo} != null && $P{tiene_logo}]]></printWhenExpression>
        </reportElement>
        <imageExpression><![CDATA[$P{logo_empresa}]]></imageExpression>
      </image>

      <!-- Nombre comercial -->
      <textField textAdjust="StretchHeight">
        <reportElement x="0" y="44" width="206" height="12" uuid="aa000002-0000-0000-0000-000000000002"/>
        <textElement textAlignment="Center">
          <font fontName="DejaVu Sans" size="9" isBold="true"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{empresa_nombre}]]></textFieldExpression>
      </textField>

      <!-- Razón social -->
      <textField textAdjust="StretchHeight">
        <reportElement x="0" y="57" width="206" height="10" uuid="aa000003-0000-0000-0000-000000000003"/>
        <textElement textAlignment="Center">
          <font fontName="DejaVu Sans" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{empresa_razon_social}]]></textFieldExpression>
      </textField>

      <!-- Identificación -->
      <textField>
        <reportElement x="0" y="68" width="206" height="8" uuid="aa000004-0000-0000-0000-000000000004"/>
        <textElement textAlignment="Center">
          <font fontName="DejaVu Sans" size="6"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{empresa_identificacion}]]></textFieldExpression>
      </textField>

      <!-- Teléfono -->
      <textField>
        <reportElement x="0" y="77" width="206" height="8" uuid="aa000005-0000-0000-0000-000000000005">
          <printWhenExpression><![CDATA[$P{empresa_telefono} != null && !$P{empresa_telefono}.trim().isEmpty()]]></printWhenExpression>
        </reportElement>
        <textElement textAlignment="Center">
          <font fontName="DejaVu Sans" size="6"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{empresa_telefono}]]></textFieldExpression>
      </textField>

      <!-- Línea separadora -->
      <line>
        <reportElement x="0" y="90" width="206" height="1" uuid="aa000006-0000-0000-0000-000000000006"/>
        <graphicElement><pen lineStyle="Dotted"/></graphicElement>
      </line>

      <!-- Título del documento -->
      <staticText>
        <reportElement x="0" y="94" width="206" height="14" uuid="aa000007-0000-0000-0000-000000000007"/>
        <textElement textAlignment="Center">
          <font fontName="DejaVu Sans" size="10" isBold="true"/>
        </textElement>
        <text><![CDATA[RECIBO DE PAGO]]></text>
      </staticText>

      <!-- Número recibo -->
      <textField>
        <reportElement x="0" y="109" width="206" height="10" uuid="aa000008-0000-0000-0000-000000000008"/>
        <textElement textAlignment="Center">
          <font fontName="DejaVu Sans" size="8" isBold="true"/>
        </textElement>
        <textFieldExpression><![CDATA["Recibo #" + $P{numero_recibo}]]></textFieldExpression>
      </textField>

      <!-- Fecha y cajero -->
      <textField>
        <reportElement x="0" y="120" width="103" height="8" uuid="aa000009-0000-0000-0000-000000000009"/>
        <textElement textAlignment="Left">
          <font fontName="DejaVu Sans" size="6"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{fecha_pago}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="103" y="120" width="103" height="8" uuid="aa000010-0000-0000-0000-000000000010"/>
        <textElement textAlignment="Right">
          <font fontName="DejaVu Sans" size="6"/>
        </textElement>
        <textFieldExpression><![CDATA["Cajero: " + $P{cajero_nombre}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <!-- ===== CLIENTE + FACTURA ORIGEN ===== -->
  <pageHeader>
    <band height="50">
      <line>
        <reportElement x="0" y="0" width="206" height="1" uuid="aa000011-0000-0000-0000-000000000011"/>
        <graphicElement><pen lineStyle="Dotted"/></graphicElement>
      </line>

      <staticText>
        <reportElement x="0" y="3" width="206" height="8" uuid="aa000012-0000-0000-0000-000000000012"/>
